{
  "description": "Asks user before every git commit; preserves GPG signing and pinentry passphrase flow",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PLUGIN_ROOT}/hooks/commit_guard_hook.py"
          }
        ]
      }
    ]
  }
}
